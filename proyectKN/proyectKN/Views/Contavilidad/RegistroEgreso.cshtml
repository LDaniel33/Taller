@model proyectKN.Models.Egreso
@{
    ViewData["Title"] = "RegistroEgreso";
    Layout = "_Layout";
}

<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- CSS -->
    <link rel="stylesheet" href="~/css/cards.css" />
</head>

<body>

    <div class="container mt-4">

        <!-- Header flotante -->
        <div class="profile-header">
            <h2>Registro de Egreso</h2>
            <p>Registrar un nuevo Egreso</p>
        </div>

        <!-- FORMULARIO -->
        <div class="card">
            <form asp-action="RegistroEgreso"
                  asp-controller="Contavilidad"
                  method="post"
                  class="card-body">

                <div class="row">
                    <div class="field">
                        <label>Motivo del Egreso</label>
                        <input type="text" asp-for="Motivo" class="form-control" required>

                        </div>

                        <div class="field">
                            <label>Monto</label>
                            <input type="text" asp-for="Monto" class="form-control" required>

                            </div>

                        </div>

                        <div class="row">
                            <div class="field">
                                <label>Cantidad de articulos</label>
                                <input type="number" asp-for="Cantidad" class="form-control" required>

                                </div>

                                <div class="field">
                                    <label>Metodo de pago</label>
                                    <select asp-for="MetodoPago" class="form-control" required>
                                        <option value="Tarjeta">Tarjeta</option>
                                        <option value="Efectivo">Efectivo</option>
                                        <option value="Sinpe">Sinpe</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>Creado por</label>
                                    <input type="text" class="form-control"
                                           value="@Context.Session.GetString("NombreUsuario")" readonly />
                                </div>
                            </div>

                            <button type="submit" class="btn">Crear</button>

                        </form>
                    </div>

                    <!-- TABLA -->
                    <div class="table-registros">
                        <div class="table-title">Egresos Registrados</div>

                        <table>
                            <thead>
                                <tr>
                                    <th>Motivo del Egreso</th>
                                    <th>Monto</th>
                                    <th>Cantidad</th>
                                    <th>Metodo de pago</th>
                                    <th>Registrado por</th>
                                    <th>Fecha de registro</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.Egreso != null)
                                {
                                    foreach (var item in ViewBag.Egreso)
                                    {
                                        <tr>
                                            <td>@item.Motivo</td>
                                            <td>@item.Monto</td>
                                            <td>@item.Cantidad</td>
                                            <td>@item.MetodoPago</td>
                                            <td>@item.RegistradoPor</td>
                                            <td>@item.Fecha</td>
                                            <td>


                                                <a asp-controller="Contavilidad"
                                                       asp-action="EditarEgreso"
                                                       asp-route-id="@item.Consecutivo"
                                                       class="btn btn-warning btn-sm">
                                                    Editar
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted text-white">
                                            No hay productos registrados
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- JS -->
            </body>
