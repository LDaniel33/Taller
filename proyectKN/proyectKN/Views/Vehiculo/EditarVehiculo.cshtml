@model proyectKN.Models.Vehiculo

@{
    ViewData["Title"] = "Editar Vehículo";
    Layout = "_Layout";
}

<div class="container mt-4">
    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger text-center text-danger">
            @ViewBag.Mensaje
        </div>
    }
    <!-- Header flotante -->
    <div class="profile-header">
        <h2>Editar vehículo</h2>
        <p>Modificar los datos del vehículo</p>
    </div>

    <!-- FORMULARIO -->
    <div class="card">
        <form asp-action="EditarVehiculo"
              asp-controller="Vehiculo"
              method="post"
              class="card-body">

            <input type="hidden" asp-for="Consecutivo" />

            <div class="row">
                <div class="field">
                    <label>Marca del vehículo</label>
                    <input type="text" asp-for="Marca" class="form-control" readonly required>
                    </div>
                    <div class="field">
                        <label>Modelo del vehículo</label>
                        <input type="text" asp-for="Modelo" class="form-control" readonly required>
                        </div>
                        <div class="field">
                            <label>Año del vehículo</label>
                            <input type="number" asp-for="Anio" class="form-control" readonly required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="field">
                                <label>Placa del vehículo</label>
                                <input type="text" asp-for="Placa" class="form-control" readonly required>
                                </div>

                                <div class="field">
                                    <label>Cédula</label>
                                    <input type="text" asp-for="Cedula" class="form-control" required onkeyup="ConsultarDueno();">
                                    </div>

                                    <div class="field">
                                        <label>Nombre del propietario</label>
                                        <input type="text" asp-for="Nombre_Cliente" class="form-control" readonly required>
                                        </div>
                                    </div>

                                    <div class="row">

                                        <div class="field">
                                            <label>Teléfono</label>
                                            <input type="text" id="Telefono" asp-for="Telefono" class="form-control" maxlength="8" required>
                                            </div>
                                            <div class="field">
                                                <label>Estado</label>
                                                <select asp-for="Estado" class="form-control" required>
                                                    <option value="">Seleccione un Estado</option>
                                                    @if (ViewBag.Estado != null)
                                                    {
                                                        foreach (var e in ViewBag.Estado)
                                                        {
                                                            <option value="@e.Consecutivo">@e.Estado</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                    
                                        </div>

                                        <div class="row">
                   
                                            <div class="field full">
                                                <label>Problema reportado</label>
                                                <textarea asp-for="Problema" class="form-control" rows="4" required></textarea>
                                            </div>

                                            <div class="field full">
                                                <label>Revición Incial</label>
                                                <textarea asp-for="Revision" class="form-control" rows="4" readonly required></textarea>
                                            </div>

                                        </div>

                                        <div class="mt-4">
                                            <button type="submit" class="btn">Guardar Cambios</button>
                                            <a asp-action="RegistroVehiculo" class="btn btn-secondary">Cancelar</a>
                                        </div>

                                    </form>
                                </div>
                                <script src="~/js/vehiculo.js"></script>
                            </div>