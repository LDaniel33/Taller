<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">


    <title>@ViewBag.Title - Taller La Unión</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet" />

    <!-- Soft UI Dashboard CSS -->   
    <link href="~/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/main.css" rel="stylesheet" />
    <link href="~/css/cards.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/FileName.css" rel="stylesheet" />

    @* <link href="~/css/fondo.css" rel="stylesheet" /> *@
    <link rel="shortcut icon" href="~/lib/img/logo.jpeg" />

</head>
@{
    var rol = Context.Session.GetString("RolUsuario");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
}
<body class="g-sidenav-show bg-gray-100 d-flex flex-column min-vh-100">
   
    <header id="header" class="header dark-background d-flex flex-column">
        <i class="header-toggle d-xl-none bi bi-list"></i>

        <a asp-controller="Home" asp-action="Index" class="logo d-flex align-items-center justify-content-center">
            <h1 class="sitename">Taller la Unión</h1>
        </a>

        @if (Context.Session.GetString("NombreUsuario") != null)
        {
            <div class="text-center mt-3">
                <span class="badge bg-light text-dark px-3 py-2">
             👤 @Context.Session.GetString("NombreUsuario")
                </span>
                <br />
                <a asp-controller="Home" asp-action="CerrarSesion" class="text-danger small">
                    Cerrar sesión
                </a>
            </div>
        }

        <nav id="navmenu" class="navmenu">
            <ul>

                <li>
                    <a asp-controller="Home" asp-action="Index"
                           class="@(currentController == "Home" ? "active" : "")">
                        <i class="bi bi-house-door-fill navicon"></i> Inicio
                    </a>
                </li>

                @if (rol == "Administrador")
                {
                    <li>
                        <a asp-controller="Usuario" asp-action="RegistroUsuario"
                               class="@(currentController == "Usuario" ? "active" : "")">
                            <i class="bi bi-people-fill navicon"></i> Gestión Usuarios
                        </a>
                    </li>
                }

                <li>
                    <a asp-controller="Cita" asp-action="RegistroCita"
                           class="@(currentController == "Cita" ? "active" : "")">
                        <i class="bi bi-calendar-check-fill navicon"></i> Citas
                    </a>
                </li>

                @if (rol == "Administrador" || rol == "Encargado")
                {
                    <li>
                        <a asp-controller="Inventario" asp-action="RegistroInventario"
                               class="@(currentController == "Inventario" ? "active" : "")">
                            <i class="bi bi-box-seam-fill navicon"></i> Inventario
                        </a>
                    </li>
                }

                <li>
                    <a asp-controller="Vehiculo" asp-action="RegistroVehiculo"
                           class="@(currentController == "Vehiculo" ? "active" : "")">
                        <i class="bi bi-car-front-fill navicon"></i> Gestión de Vehículos
                    </a>
                </li>

                @if (rol == "Administrador" || rol == "Encargado")
                {
                    <li>
                        <a asp-controller="Proveedor" asp-action="RegistroProveedor"
                               class="@(currentController == "Proveedor" ? "active" : "")">
                            <i class="bi bi-people-fill navicon"></i> Proveedores
                        </a>
                    </li>
                }

                @if (rol == "Administrador" || rol == "Encargado")
                {
                    <li class="dropdown @(currentController == "Contavilidad" ? "active" : "")">

                        <a href="#">
                            <i class="bi bi-menu-button navicon"></i>
                            <span>Contabilidad</span>
                            <i class="bi bi-chevron-down toggle-dropdown"></i>
                        </a>

                        <ul class="dropdown-menu">

                            <li>
                                <a asp-controller="Contavilidad" asp-action="RegistroEgreso">
                                    <i class="bi bi-arrow-down-circle-fill me-2"></i>
                                    Egresos
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Contavilidad" asp-action="RegistroIngreso">
                                    <i class="bi bi-arrow-up-circle-fill me-2"></i>
                                    Ingresos
                                </a>
                            </li>

                        </ul>
                    </li>
                }

                @if (rol == "Administrador")
                {
                    <li>
                        <a asp-controller="Reporteria" asp-action="Reporteria"
                               class="@(currentController == "Reporteria" ? "active" : "")">
                            <i class="bi bi-people-fill navicon"></i> Reportes
                        </a>
                    </li>
                }

            </ul>
        </nav>
    </header>

    <div class="main-content-adjust">
        <div class="container pb-4">
            @if (TempData["Success"] != null)
            {
                <div id="mensajeSuccess" class="alert alert-success alert-dismissible fade show text-center" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div id="mensajeError" class="alert alert-danger alert-dismissible fade show text-center" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>
    <!-- footer -->
    <footer class="footer py-4 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center">
                    <p class="mb-0 text-secondary">
                        © <script>document.write(new Date().getFullYear())</script> Taller La Unión
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!--JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/jquery.validation/1.19.5/jquery.validate.min.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/mensaje.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>