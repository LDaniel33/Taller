  "components": {
    "schemas": {
      "CitaRequest": {
        "required": [
          "consecutivo",
          "nombreCliente",
          "cedula",
          "fechaCita",
          "horaCita",
          "telefono",
          "email",
          "servicio",
          "estado",
          "creadaPor"
        ],
        "type": "object",
        "properties": {
          "consecutivo": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "nombreCliente": {
            "type": "string"
          },
          "cedula": {
            "type": "string"
          },
          "fechaCita": {
            "type": "string",
            "format": "date-time"
          },
          "horaCita": {
            "pattern": "^-?(\\d+\\.)?\\d{2}:\\d{2}:\\d{2}(\\.\\d{1,7})?$",
            "type": "string"
          },
          "telefono": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "email": {
            "type": "string"
          },
          "servicio": {
            "type": "string"
          },
          "estado": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "creadaPor": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "modificadoPor": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "fechaModificacion": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "EgresoRequest": {
        "required": [
          "consecutivo",
          "motivo",
          "monto",
          "cantidad",
          "fecha",
          "registradoPor",
          "metodoPago"
        ],
        "type": "object",
        "properties": {
          "consecutivo": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
