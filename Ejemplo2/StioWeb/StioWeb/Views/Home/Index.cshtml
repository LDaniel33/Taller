@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}


<section id="hero" class="s-hero target-section">

    <div class="s-hero__bg">
        <div class="gradient-overlay"></div>
    </div>

    <div class="row s-hero__content">
        <div class="column">

            <h1>Taller La Unión</h1>
          
            <div class="s-hero__content-about">

                <p>
                    Mantenimiento, diagnóstico y reparación automotriz
                    con atención profesional, rápida y confiable.
                </p>
                <div class="hero-buttons">
                    <a href="#services" class="btn btn--stroke smoothscroll">Ver servicios</a>
                    <a href="https://wa.me/50688887777?text=Hola%20quiero%20información%20sobre%20sus%20servicios"
                           target="_blank"
                           class="btn btn--primary">
                        Solicitar información
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="s-about" about-bg">
    >

    <div class="horizontal-line"></div>

    <div class="row">
        <div class="column large-12">

            <div class="section-title" data-num="01" data-aos="fade-up">
                <h3 class="h6">Nosotros</h3>
            </div>

        </div>

        <div class="column large-6 w-900-stack s-about__intro-text">
            <h1 class="display-1" data-aos="fade-up">
                Brindamos soluciones automotrices integrales con enfoque en calidad,
                seguridad y confianza.
            </h1>

            <p class="lead" data-aos="fade-up">
                En Taller La Unión contamos con personal capacitado, experiencia en el sector
                y herramientas adecuadas para ofrecer un servicio eficiente y responsable.
            </p>
        </div>

        <div class="column large-6 w-900-stack s-about__photo-block">
            <div class="s-about__photo" data-aos="fade-up"></div>
        </div>
    </div>

    <div class="row block-large-1-2 block-tab-full s-about__process item-list">
        <div class="column item item-process" data-aos="fade-up">
            <h3 class="item-title">Calidad Garantizada</h3>
            <p>
                Trabajamos bajo altos estándares para asegurar resultados confiables
                y la satisfacción de cada cliente.
            </p>
        </div>
        <div class="column item item-process" data-aos="fade-up">
            <h3 class="item-title">Personal Especializado</h3>
            <p>
                Nuestro equipo está preparado para atender distintas necesidades
                mecánicas y eléctricas con profesionalismo.
            </p>
        </div>

        <div class="column item item-process" data-aos="fade-up">
            <h3 class="item-title">Atención personalizada</h3>
            <p>
                Brindamos asesoría profesional y atención cercana, explicando detalladamente
                cada procedimiento realizado en el vehículo.
            </p>
        </div>
        <div class="column item item-process" data-aos="fade-up">
            <h3 class="item-title">Confianza y respaldo</h3>
            <p>
                Nos esforzamos por ofrecer rapidez, eficiencia y confianza, convirtiéndonos
                en el taller de preferencia de nuestros clientes.
            </div>
        </div>

    </section>


    <section id="services" class="s-services">

        <div class="row">
            <div class="column large-12">
                <div class="section-title" data-num="02" data-aos="fade-up">
                    <h3 class="h6">Servicios</h3>
                </div>
            </div>
            <div class="column large-6 w-900-stack">
                <h1 class="display-1" data-aos="fade-up">
                    Servicios automotrices diseñados para mantener su vehículo
                    en óptimas condiciones.
                    
                </h1>
            </div>
            <div class="column large-6 w-900-stack">
                <p class="lead" data-aos="fade-up">
                    Desde mantenimiento preventivo hasta reparaciones especializadas, siempre con
                    la garantía de calidad y respaldo profesional.
                </p>
            </div>
        </div>

        <div class="row block-large-1-3 block-tab-full s-services__services item-list">

            <div class="column item item-service card-service" data-aos="fade-up">
                <div class="icon"><i class="fas fa-tools"></i></div>
                <h3 class="item-title">Mantenimiento preventivo</h3>
                <p>Revisiones periódicas para prevenir fallas y prolongar la vida útil del vehículo.</p>
            </div>

            <div class="column item item-service card-service" data-aos="fade-up">
                <div class="icon"><i class="fas fa-oil-can"></i></div>
                <h3 class="item-title">Cambio de aceite</h3>
                <p>Lubricación y reemplazo de filtros para un mejor rendimiento del motor.</p>
            </div>

            <div class="column item item-service card-service" data-aos="fade-up">
                <div class="icon"><i class="fas fa-car-crash"></i></div>
                <h3 class="item-title">Sistema de frenos</h3>
                <p>Inspección y reparación para garantizar la seguridad del vehículo.</p>
            </div>

            <div class="column item item-service card-service" data-aos="fade-up">
                <div class="icon"><i class="fas fa-cogs"></i></div>
                <h3 class="item-title">Alineación y balanceo</h3>
                <p>Mejora la estabilidad y prolonga la vida de las llantas.</p>
            </div>

            <div class="column item item-service card-service" data-aos="fade-up">
                <div class="icon"><i class="fas fa-car-battery"></i></div>
                <h3 class="item-title">Servicio eléctrico</h3>
                <p>Revisión de batería, alternador, luces y sistema eléctrico.</p>
            </div>

            <div class="column item item-service card-service" data-aos="fade-up">
                <div class="icon"><i class="fas fa-search"></i></div>
                <h3 class="item-title">Diagnóstico general</h3>
                <p>Evaluación completa del vehículo para detectar fallas.</p>
            </div>

        </div>
    </section> 

    <section id="portfolio" class="s-portfolio">
    <div class="row s-porfolio__top">
        <div class="column large-6 w-900-stack">
            <div class="section-title" data-num="03" data-aos="fade-up">
                <h3 class="h6">Ubicación</h3>
            </div>
        </div>

        <div class="column large-6 w-900-stack">
            <h1 class="display-1" data-aos="fade-up">
                Estamos listos para atenderle y brindarle a su vehículo
                el cuidado que necesita con un servicio rápido y confiable.
            </h1>
        </div>
    </div>

    <div class="row mt-5" data-aos="fade-up">
        <div class="column large-12">
            <div class="map-container">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3929.123456789!2d-84.083333!3d9.933333!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0e123456789ab%3A0xabcdef123456789!2sTaller%20La%20Uni%C3%B3n!5e0!3m2!1ses!2scr!4v1712345678901!5m2!1ses!2scr"
                    width="100%"
                    height="500"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>
    </div>
</section>
